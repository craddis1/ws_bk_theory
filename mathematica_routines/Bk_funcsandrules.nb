           RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"index", " ", "backwards"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "6"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pkrules", "=", 
