Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "wide", " ", "angle", " ", "and", " ", "radial", " ", "redhsift", " ", 
     "term", " ", "contribution"}], "..."}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"wideangleexp", " ", ":=", " ", 
    RowBox[{"Join", "[", 
