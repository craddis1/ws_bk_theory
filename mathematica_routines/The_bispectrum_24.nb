Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"H", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "L_"}], "]"}], ":=", " ", 
   RowBox[{"ThreeJSymbol", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"l2", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"L", ",", "0"}], "}"}]}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"won", "'"}], "t", " ", "be", " ", "using", " ", "this", " ", 
    "boi"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Nlll", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "L_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "l1"}], " ", "+", "1"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "l2"}], " ", "+", "1"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "L"}], "+", "1"}], ")"}]}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"integrate", " ", "over", " ", "triposh", " ", "module"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"inttriposh", "[", 
    RowBox[{"exprs_", ",", "l1_", ",", "l2_", ",", "L_"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{
    RowBox[{"Nlll", "[", 
     RowBox[{"l1", ",", "l2", ",", "L"}], "]"}], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"triposh", "[", 
           RowBox[{"l1", ",", "l2", ",", "L"}], "]"}], "exprs"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Sin", "[", "theta", "]"}], "->", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{"mu12", "^", "2"}]}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}]}]}], ",", 
           RowBox[{
            RowBox[{"Cos", "[", "theta", "]"}], "->", "mu12"}], ",", 
           RowBox[{
            RowBox[{"Cos", "[", "theta1", "]"}], "->", " ", "mu"}]}], "}"}]}],
         ",", 
        RowBox[{"{", 
         RowBox[{"mu12", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"mu", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Sum", " ", "over", " ", "wigner"}], "-", 
     RowBox[{"3", "j", " ", "for", " ", "k1"}]}], " ", "->", " ", "z"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"triposh", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "L_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{"sumlim", " ", "=", " ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"l2", "<", "L"}], ",", "l2", ",", "L"}], "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ThreeJSymbol", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"l1", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l2", ",", 
           RowBox[{"-", "M"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"L", ",", "M"}], "}"}]}], "]"}], 
       RowBox[{"Conjugate", "[", 
        RowBox[{"SphericalHarmonicY", "[", 
         RowBox[{"l2", ",", 
          RowBox[{"-", "M"}], ",", "theta", ",", "0"}], "]"}], "]"}], 
       RowBox[{"Conjugate", "[", 
        RowBox[{"SphericalHarmonicY", "[", 
         RowBox[{"L", ",", "M", ",", "theta1", ",", "\[Phi]"}], "]"}], 
        "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"M", ",", 
        RowBox[{"-", "sumlim"}], " ", ",", "sumlim"}], " ", "}"}]}], "]"}]}], 
