Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"H", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "L_"}], "]"}], ":=", " ", 
   RowBox[{"ThreeJSymbol", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"l2", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"L", ",", "0"}], "}"}]}], "]"}]}], 
  RowBox[{"(*", 
