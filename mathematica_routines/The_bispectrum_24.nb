   RowBox[{"(*", 
    RowBox[{"mixed", " ", "terms"}], "*)"}], 
   RowBox[{"(*", 
    RowBox[{
    "so", " ", "get", " ", "mixed", " ", "terms", " ", "and", " ", "make", 
     " ", "sure", " ", "it", " ", "doesnt", " ", "have", " ", "other", " ", 
     "parts"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"temp", " ", "=", " ", 
