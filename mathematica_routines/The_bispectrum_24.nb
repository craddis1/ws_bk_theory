        RowBox[{"{", 
         RowBox[{
          RowBox[{"c", "^", "2"}], "->", "0"}], "}"}]}], ")"}], "/.", 
      RowBox[{"{", 
       RowBox[{"c", "->", "1"}], "}"}]}]}], ";"}]}]}]], "Input",
